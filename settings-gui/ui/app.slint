import "./fonts/plus_jakarta_sans.ttf";
import { ScrollView } from "std-widgets.slint";
import { Theme } from "theme.slint";
import { Icons } from "icons.slint";
import {
    Card,
    NavItem,
    IconButton,
    Toggle,
    TextField,
    Dropdown,
    FieldRow,
    ToggleRow,
    StatusBadge,
    FilterCheckbox,
    FilterGroup,
    LogPill,
    TimelineHistogram,
    ObjectTreeRow,
} from "components.slint";

export struct JsonTreeNode {
    node-id: int,
    depth: int,
    key: string,
    value-preview: string,
    value-type: string,  // "string", "number", "bool", "null", "object", "array"
    expandable: bool,
    expanded: bool,
}

export struct LogEntry {
    id: int,
    time: string,
    level: string,
    target: string,
    message: string,
    expanded: bool,
    tree-nodes: [JsonTreeNode],
}

export struct FilterOption {
    label: string,
    count: string,
    checked: bool,
}

export struct ChangelogItem {
    text: string,
}

export struct ChangelogSection {
    title: string,
    items: [ChangelogItem],
}

export component AppWindow inherits Window {
    default-font-family: "Plus Jakarta Sans";
    title: "Stream Server Settings";
    icon: Icons.logo;
    preferred-width: 1040px;
    preferred-height: 720px;
    min-width: 900px;
    min-height: 600px;
    background: Theme.bg;

    // ---- Preserved properties (names must match main.rs generated accessors) ----
    in-out property <string> server-url;
    in-out property <string> status-text;
    in-out property <string> log-status;
    in-out property <string> log-dir;
    in-out property <string> current-log-path;
    in-out property <string> logs-text;
    in-out property <[LogEntry]> log-entries;
    in-out property <bool> log-is-truncated: false;
    in-out property <string> log-search;
    in-out property <bool> log-live-enabled: true;
    in-out property <bool> log-show-error: true;
    in-out property <bool> log-show-warning: true;
    in-out property <bool> log-show-info: true;
    in-out property <bool> log-show-debug: true;
    in-out property <string> log-total-count: "0";
    in-out property <string> log-visible-count: "0";
    in-out property <string> log-error-count: "0";
    in-out property <string> log-warning-count: "0";
    in-out property <string> log-info-count: "0";
    in-out property <string> log-debug-count: "0";
    in-out property <[int]> log-timeline-bins;
    in-out property <[FilterOption]> log-target-options;
    in-out property <string> log-active-target;

    in-out property <string> cache-root;
    in-out property <string> cache-size;
    in-out property <bool> proxy-streams-enabled;
    in-out property <string> bt-max-connections;
    in-out property <string> bt-handshake-timeout;
    in-out property <string> bt-request-timeout;
    in-out property <string> bt-download-speed-soft-limit;
    in-out property <string> bt-download-speed-hard-limit;
    in-out property <string> bt-min-peers-for-stable;
    in-out property <bool> bt-enable-dht;
    in-out property <bool> bt-enable-pex;
    in-out property <bool> bt-enable-lsd;
    in-out property <string> bt-encryption-mode;
    in-out property <bool> bt-anonymous-mode;
    in-out property <bool> bt-allow-multiple-connections-per-ip;
    in-out property <string> bt-listen-interfaces;
    in-out property <string> bt-outgoing-interfaces;
    in-out property <string> bt-outgoing-port;
    in-out property <string> bt-num-outgoing-ports;
    in-out property <string> bt-proxy-type;
    in-out property <string> bt-proxy-host;
    in-out property <string> bt-proxy-port;
    in-out property <string> bt-proxy-username;
    in-out property <string> bt-proxy-password;
    in-out property <bool> bt-proxy-hostnames;
    in-out property <bool> bt-proxy-peer-connections;
    in-out property <bool> bt-proxy-tracker-connections;
    in-out property <bool> bt-proxy-send-host-in-connect;
    in-out property <bool> bt-validate-https-trackers;
    in-out property <bool> bt-ssrf-mitigation;
    in-out property <bool> auto-update-enabled;
    in-out property <string> update-channel;
    in-out property <string> update-check-interval-hours;
    in-out property <bool> seeding-enabled;
    in-out property <string> changelog-status;
    in-out property <string> changelog-current-version;
    in-out property <string> changelog-latest-version;
    in-out property <string> changelog-release-url;
    in-out property <string> changelog-published-at;
    in-out property <[ChangelogSection]> changelog-sections;

    // ---- New: which sidebar section is shown ----
    in-out property <int> selected-section: 0;
    in-out property <length> sidebar-width: 232px;

    changed selected-section => {
        root.section-changed(root.selected-section);
    }

    // ---- Preserved callbacks ----
    callback refresh-settings();
    callback apply-settings();
    callback refresh-logs();
    callback open-logs-folder();
    callback export-diagnostics();
    callback refresh-changelog(bool);
    callback open-changelog-release();
    callback log-search-edited(string);
    callback toggle-log-row(int);
    callback toggle-log-live(bool);
    callback set-log-level-filter(string, bool);
    callback set-log-target-filter(string, bool);
    callback toggle-tree-node(int, int);
    callback section-changed(int);

    property <[string]> section-titles: [
        "General", "Privacy", "Network", "Proxy", "Speed", "Updates & Seeding", "Logs"
    ];

    Rectangle {
        width: 100%;
        height: 100%;

        HorizontalLayout {
            // ============================ Sidebar ============================
            Rectangle {
                width: root.sidebar-width;
                background: Theme.bg;
                clip: true;

            // right divider
            Rectangle {
                x: parent.width - 1px;
                width: 1px;
                background: Theme.border;
            }

            VerticalLayout {
                padding: 16px;
                spacing: 5px;

                // Brand
                HorizontalLayout {
                    spacing: root.sidebar-width > 120px ? 11px : 0px;
                    padding-bottom: 10px;
                    alignment: root.sidebar-width > 120px ? LayoutAlignment.start : LayoutAlignment.center;
                    Rectangle {
                        width: 36px;
                        height: 36px;
                        background: transparent;
                        Image {
                            source: Icons.logo;
                            width: 32px;
                            height: 32px;
                            image-fit: contain;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                        }
                    }
                    if root.sidebar-width > 120px : VerticalLayout {
                        alignment: center;
                        spacing: 1px;
                        Text {
                            text: "Stream Server";
                            color: Theme.text;
                            font-size: 15px;
                            font-weight: 700;
                        }
                        Text {
                            text: "Settings";
                            color: Theme.text-muted;
                            font-size: 11px;
                        }
                    }
                }

                NavItem { label: root.sidebar-width > 120px ? "General" : ""; icon: Icons.general; index: 0; selected <=> root.selected-section; }
                NavItem { label: root.sidebar-width > 120px ? "Privacy" : ""; icon: Icons.privacy; index: 1; selected <=> root.selected-section; }
                NavItem { label: root.sidebar-width > 120px ? "Network" : ""; icon: Icons.network; index: 2; selected <=> root.selected-section; }
                NavItem { label: root.sidebar-width > 120px ? "Proxy" : ""; icon: Icons.proxy; index: 3; selected <=> root.selected-section; }
                NavItem { label: root.sidebar-width > 120px ? "Speed" : ""; icon: Icons.speed; index: 4; selected <=> root.selected-section; }
                NavItem { label: root.sidebar-width > 120px ? "Updates & Seeding" : ""; icon: Icons.updates; index: 5; selected <=> root.selected-section; }
                NavItem { label: root.sidebar-width > 120px ? "Logs" : ""; icon: Icons.logs; index: 6; selected <=> root.selected-section; }

                Rectangle { vertical-stretch: 1; }

                // Theme toggle
                Rectangle {
                    height: 40px;
                    border-radius: Theme.radius-sm;
                    background: theme-touch.has-hover ? Theme.surface-hover : Theme.surface-alt;
                    animate background { duration: 120ms; }
                    theme-touch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { Theme.dark = !Theme.dark; }
                    }
                    HorizontalLayout {
                        padding-left: root.sidebar-width > 120px ? 12px : 0px;
                        padding-right: root.sidebar-width > 120px ? 12px : 0px;
                        spacing: root.sidebar-width > 120px ? 10px : 0px;
                        alignment: root.sidebar-width > 120px ? LayoutAlignment.start : LayoutAlignment.center;
                        Rectangle {
                            width: 18px;
                            height: parent.height;

                            Image {
                                source: Theme.dark ? Icons.moon : Icons.sun;
                                width: 18px;
                                height: 18px;
                                x: (parent.width - self.width) / 2;
                                y: (parent.height - self.height) / 2;
                                colorize: Theme.text-muted;
                            }
                        }
                        if root.sidebar-width > 120px : Text {
                            height: parent.height;
                            text: Theme.dark ? "Dark theme" : "Light theme";
                            color: Theme.text;
                            font-size: Theme.fs-label;
                            font-weight: 500;
                            vertical-alignment: center;
                        }
                    }
                }

                // Server URL + connection status
                if root.sidebar-width > 120px : Text {
                    text: root.server-url;
                    color: Theme.text-muted;
                    font-size: 11px;
                    overflow: elide;
                }
                if root.sidebar-width > 120px : StatusBadge { text: root.status-text; }
            }
        }

        // ============================ Content ============================
        VerticalLayout {
            horizontal-stretch: 1;
            padding: 24px;
            spacing: 18px;

            // Header
            HorizontalLayout {
                height: 38px;
                spacing: 12px;

                Text {
                    text: root.section-titles[root.selected-section];
                    color: Theme.text;
                    font-size: Theme.fs-title;
                    font-weight: 700;
                    horizontal-stretch: 1;
                    vertical-alignment: center;
                }

                IconButton {
                    text: "Refresh";
                    icon: Icons.refresh;
                    visible: root.selected-section != 6;
                    clicked => { root.refresh-settings(); }
                }

                IconButton {
                    text: "Apply";
                    icon: Icons.apply;
                    primary: true;
                    visible: root.selected-section != 6;
                    clicked => { root.apply-settings(); }
                }
            }

            // Body
            if root.selected-section != 6 : ScrollView {
                vertical-stretch: 1;

                VerticalLayout {
                    spacing: 16px;

                    // ---------------- General ----------------
                    if root.selected-section == 0 : Card {
                        FieldRow {
                            label: "Server";
                            description: "Read-only address this app talks to";
                            TextField { text <=> root.server-url; enabled: false; horizontal-stretch: 1; }
                        }
                        FieldRow {
                            label: "Cache root";
                            description: "Folder for cached pieces";
                            TextField { text <=> root.cache-root; horizontal-stretch: 1; }
                        }
                        FieldRow {
                            label: "Cache size (bytes)";
                            TextField { text <=> root.cache-size; horizontal-stretch: 1; }
                        }
                        ToggleRow { label: "Proxy streams"; checked <=> root.proxy-streams-enabled; }
                    }

                    // ---------------- Privacy ----------------
                    if root.selected-section == 1 : Card {
                        ToggleRow { label: "Enable DHT"; checked <=> root.bt-enable-dht; }
                        ToggleRow { label: "Enable Peer Exchange"; checked <=> root.bt-enable-pex; }
                        ToggleRow { label: "Enable Local Peer Discovery"; checked <=> root.bt-enable-lsd; }
                        FieldRow {
                            label: "Encryption mode";
                            Dropdown {
                                horizontal-stretch: 1;
                                value <=> root.bt-encryption-mode;
                                model: [
                                    { label: "Allow (prefer encryption)", value: "allow" },
                                    { label: "Require encryption", value: "require" },
                                    { label: "Disable encryption", value: "disable" },
                                ];
                            }
                        }
                        ToggleRow { label: "Anonymous mode"; checked <=> root.bt-anonymous-mode; }
                        ToggleRow { label: "Allow multiple connections per IP"; checked <=> root.bt-allow-multiple-connections-per-ip; }
                        ToggleRow { label: "Validate HTTPS trackers"; checked <=> root.bt-validate-https-trackers; }
                        ToggleRow { label: "SSRF mitigation"; checked <=> root.bt-ssrf-mitigation; }
                    }

                    // ---------------- Network ----------------
                    if root.selected-section == 2 : Card {
                        FieldRow {
                            label: "Listen interfaces";
                            TextField { text <=> root.bt-listen-interfaces; horizontal-stretch: 1; }
                        }
                        FieldRow {
                            label: "Outgoing interfaces";
                            TextField { text <=> root.bt-outgoing-interfaces; horizontal-stretch: 1; }
                        }
                        FieldRow {
                            label: "Outgoing port";
                            TextField { text <=> root.bt-outgoing-port; horizontal-stretch: 1; }
                        }
                        FieldRow {
                            label: "Outgoing port count";
                            TextField { text <=> root.bt-num-outgoing-ports; horizontal-stretch: 1; }
                        }
                    }

                    // ---------------- Proxy ----------------
                    if root.selected-section == 3 : Card {
                        FieldRow {
                            label: "Proxy type";
                            Dropdown {
                                horizontal-stretch: 1;
                                value <=> root.bt-proxy-type;
                                model: [
                                    { label: "None", value: "none" },
                                    { label: "SOCKS4", value: "socks4" },
                                    { label: "SOCKS5", value: "socks5" },
                                    { label: "SOCKS5 (auth)", value: "socks5Password" },
                                    { label: "HTTP", value: "http" },
                                    { label: "HTTP (auth)", value: "httpPassword" },
                                ];
                            }
                        }
                        FieldRow {
                            label: "Proxy host";
                            TextField { text <=> root.bt-proxy-host; horizontal-stretch: 1; }
                        }
                        FieldRow {
                            label: "Proxy port";
                            TextField { text <=> root.bt-proxy-port; horizontal-stretch: 1; }
                        }
                        FieldRow {
                            label: "Proxy username";
                            TextField { text <=> root.bt-proxy-username; horizontal-stretch: 1; }
                        }
                        FieldRow {
                            label: "Proxy password";
                            TextField { text <=> root.bt-proxy-password; password: true; horizontal-stretch: 1; }
                        }
                        ToggleRow { label: "Proxy hostnames"; checked <=> root.bt-proxy-hostnames; }
                        ToggleRow { label: "Proxy peer connections"; checked <=> root.bt-proxy-peer-connections; }
                        ToggleRow { label: "Proxy tracker connections"; checked <=> root.bt-proxy-tracker-connections; }
                        ToggleRow { label: "Send hostname in HTTP CONNECT"; checked <=> root.bt-proxy-send-host-in-connect; }
                    }

                    // ---------------- Speed ----------------
                    if root.selected-section == 4 : Card {
                        FieldRow {
                            label: "Max connections";
                            TextField { text <=> root.bt-max-connections; horizontal-stretch: 1; }
                        }
                        FieldRow {
                            label: "Handshake timeout (ms)";
                            TextField { text <=> root.bt-handshake-timeout; horizontal-stretch: 1; }
                        }
                        FieldRow {
                            label: "Request timeout (ms)";
                            TextField { text <=> root.bt-request-timeout; horizontal-stretch: 1; }
                        }
                        FieldRow {
                            label: "Download soft limit";
                            description: "Bytes/s, 0 = unlimited";
                            TextField { text <=> root.bt-download-speed-soft-limit; horizontal-stretch: 1; }
                        }
                        FieldRow {
                            label: "Download hard limit";
                            description: "Bytes/s, 0 = unlimited";
                            TextField { text <=> root.bt-download-speed-hard-limit; horizontal-stretch: 1; }
                        }
                        FieldRow {
                            label: "Min stable peers";
                            TextField { text <=> root.bt-min-peers-for-stable; horizontal-stretch: 1; }
                        }
                    }

                    // ---------------- Updates & Seeding ----------------
                    if root.selected-section == 5 : Card {
                        ToggleRow { label: "Auto update"; checked <=> root.auto-update-enabled; }
                        FieldRow {
                            label: "Update channel";
                            Dropdown {
                                horizontal-stretch: 1;
                                value <=> root.update-channel;
                                model: [
                                    { label: "Stable", value: "stable" },
                                    { label: "Prerelease (beta)", value: "prerelease" },
                                ];
                            }
                        }
                        FieldRow {
                            label: "Update interval (hours)";
                            TextField { text <=> root.update-check-interval-hours; horizontal-stretch: 1; }
                        }
                        ToggleRow { label: "Seed after download"; checked <=> root.seeding-enabled; }
                    }

                    if root.selected-section == 5 : Card {
                        HorizontalLayout {
                            height: 36px;
                            vertical-stretch: 0;
                            spacing: 10px;

                            Text {
                                text: "Latest Changelog";
                                color: Theme.text;
                                font-size: Theme.fs-section;
                                font-weight: 700;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }

                            IconButton {
                                text: "Refresh";
                                icon: Icons.refresh;
                                clicked => { root.refresh-changelog(true); }
                            }

                            if root.changelog-release-url != "" : IconButton {
                                text: "Open release";
                                icon: Icons.export;
                                clicked => { root.open-changelog-release(); }
                            }
                        }

                        HorizontalLayout {
                            spacing: 10px;
                            height: 30px;
                            vertical-stretch: 0;

                            StatusBadge {
                                text: root.changelog-current-version != "" ? "Current " + root.changelog-current-version : "Current unknown";
                                dot-color: Theme.text-subtle;
                                horizontal-stretch: 1;
                            }
                            StatusBadge {
                                text: root.changelog-latest-version != "" ? "Latest " + root.changelog-latest-version : "Latest unknown";
                                dot-color: Theme.accent;
                                horizontal-stretch: 1;
                            }
                            StatusBadge {
                                text: root.changelog-status;
                                dot-color: Theme.success;
                                horizontal-stretch: 2;
                            }
                        }

                        if root.changelog-published-at != "" : Text {
                            text: "Published " + root.changelog-published-at;
                            color: Theme.text-muted;
                            font-size: Theme.fs-small;
                            vertical-stretch: 0;
                        }

                        if root.changelog-sections.length == 0 : Rectangle {
                            height: 56px;
                            vertical-stretch: 0;
                            border-radius: Theme.radius-sm;
                            border-width: 1px;
                            border-color: Theme.border;
                            background: Theme.surface-alt;

                            Text {
                                text: root.changelog-status;
                                color: Theme.text-muted;
                                font-size: Theme.fs-body;
                                width: parent.width - 24px;
                                x: 12px;
                                height: parent.height;
                                vertical-alignment: center;
                                wrap: word-wrap;
                            }
                        }

                        for section in root.changelog-sections : VerticalLayout {
                            spacing: 8px;
                            vertical-stretch: 0;

                            Text {
                                text: section.title;
                                color: Theme.text;
                                font-size: Theme.fs-label;
                                font-weight: 700;
                                vertical-stretch: 0;
                            }

                            for item in section.items : HorizontalLayout {
                                spacing: 8px;
                                min-height: 22px;
                                vertical-stretch: 0;

                                Rectangle {
                                    width: 10px;
                                    height: 22px;
                                    vertical-stretch: 0;

                                    Rectangle {
                                        width: 4px;
                                        height: 4px;
                                        border-radius: 2px;
                                        background: Theme.accent;
                                        x: 3px;
                                        y: 8px;
                                    }
                                }

                                Text {
                                    text: item.text;
                                    color: Theme.text-muted;
                                    font-size: Theme.fs-body;
                                    wrap: word-wrap;
                                    horizontal-stretch: 1;
                                    vertical-stretch: 0;
                                }
                            }
                        }
                    }

                }
            }

            if root.selected-section == 6 : HorizontalLayout {
                vertical-stretch: 1;
                spacing: 0px;

                Rectangle {
                    width: 250px;
                    background: Theme.bg;
                    border-width: 1px;
                    border-color: Theme.border;

                    Rectangle {
                        x: parent.width - 1px;
                        width: 1px;
                        height: parent.height;
                        background: Theme.border;
                    }

                    VerticalLayout {
                        padding: 14px;
                        spacing: 18px;

                        HorizontalLayout {
                            height: 36px;
                            spacing: 10px;

                            Text {
                                text: "Filters";
                                color: Theme.text;
                                font-size: Theme.fs-label;
                                font-weight: 700;
                                horizontal-stretch: 1;
                                vertical-alignment: center;
                            }

                            IconButton {
                                text: "Reset";
                                icon: Icons.refresh;
                                clicked => {
                                    root.log-search = "";
                                    root.log-show-error = true;
                                    root.log-show-warning = true;
                                    root.log-show-info = true;
                                    root.log-show-debug = true;
                                    root.log-active-target = "";
                                    root.log-search-edited("");
                                    root.set-log-level-filter("all", true);
                                    root.set-log-target-filter("", false);
                                }
                            }
                        }

                        FilterGroup {
                            title: "Timeline";
                            Rectangle {
                                height: 38px;
                                border-radius: Theme.radius-sm;
                                border-width: 1px;
                                border-color: Theme.border;
                                background: Theme.surface;

                                HorizontalLayout {
                                    padding-left: 10px;
                                    padding-right: 10px;

                                    Text {
                                        text: "Past 500 log lines";
                                        color: Theme.text;
                                        font-size: Theme.fs-label;
                                        horizontal-stretch: 1;
                                        vertical-alignment: center;
                                    }

                                    Text {
                                        text: "v";
                                        color: Theme.text-muted;
                                        font-size: Theme.fs-label;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }

                        FilterGroup {
                            title: "Contains Level";
                            FilterCheckbox {
                                label: "Error";
                                count: root.log-error-count;
                                checked <=> root.log-show-error;
                                toggled(value) => { root.set-log-level-filter("error", value); }
                            }
                            FilterCheckbox {
                                label: "Warning";
                                count: root.log-warning-count;
                                checked <=> root.log-show-warning;
                                toggled(value) => { root.set-log-level-filter("warning", value); }
                            }
                            FilterCheckbox {
                                label: "Info";
                                count: root.log-info-count;
                                checked <=> root.log-show-info;
                                toggled(value) => { root.set-log-level-filter("info", value); }
                            }
                            FilterCheckbox {
                                label: "Debug / Trace";
                                count: root.log-debug-count;
                                checked <=> root.log-show-debug;
                                toggled(value) => { root.set-log-level-filter("debug", value); }
                            }
                        }

                        FilterGroup {
                            title: "Your Logs (Internal)";
                            FilterCheckbox {
                                label: "Logs from this device";
                                count: "";
                                checked: true;
                            }
                        }

                        FilterGroup {
                            title: "Targets";
                            if root.log-target-options.length == 0 : Text {
                                text: "No targets in current tail";
                                color: Theme.text-subtle;
                                font-size: Theme.fs-small;
                            }
                            for option in root.log-target-options : FilterCheckbox {
                                label: option.label;
                                count: option.count;
                                checked: option.checked;
                                toggled(value) => { root.set-log-target-filter(option.label, value); }
                            }
                        }

                        Rectangle { vertical-stretch: 1; }

                        Text {
                            text: root.current-log-path;
                            color: Theme.text-subtle;
                            font-size: 10px;
                            wrap: word-wrap;
                        }
                    }
                }

                Rectangle {
                    horizontal-stretch: 1;
                    background: Theme.bg;

                    VerticalLayout {
                        padding-left: 8px;
                        spacing: 8px;

                        HorizontalLayout {
                            height: 42px;
                            spacing: 8px;

                            TextField {
                                placeholder: "Search logs...";
                                text <=> root.log-search;
                                horizontal-stretch: 1;
                                edited(value) => { root.log-search-edited(value); }
                            }

                            Rectangle {
                                height: 36px;
                                min-width: 76px;
                                horizontal-stretch: 0;
                                border-radius: Theme.radius-sm;
                                border-width: 1px;
                                border-color: root.log-live-enabled ? Theme.accent : Theme.border;
                                background: root.log-live-enabled ? Theme.accent-soft : Theme.surface;

                                touch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => {
                                        root.log-live-enabled = !root.log-live-enabled;
                                        root.toggle-log-live(root.log-live-enabled);
                                    }
                                }

                                HorizontalLayout {
                                    padding-left: 12px;
                                    padding-right: 12px;
                                    spacing: 8px;
                                    alignment: center;

                                    Rectangle {
                                        width: 14px;
                                        height: parent.height;

                                        Image {
                                            source: Icons.live;
                                            width: 14px;
                                            height: 14px;
                                            x: (parent.width - self.width) / 2;
                                            y: (parent.height - self.height) / 2;
                                            colorize: root.log-live-enabled ? Theme.accent : Theme.text-muted;
                                        }
                                    }

                                    Text {
                                        text: "Live";
                                        color: root.log-live-enabled ? Theme.accent : Theme.text;
                                        font-size: Theme.fs-label;
                                        font-weight: 700;
                                        vertical-alignment: center;
                                    }
                                }
                            }

                            IconButton {
                                text: "";
                                icon: Icons.refresh;
                                clicked => { root.refresh-logs(); }
                            }

                            IconButton {
                                text: "";
                                icon: Icons.folder;
                                clicked => { root.open-logs-folder(); }
                            }

                            IconButton {
                                text: "";
                                icon: Icons.export;
                                clicked => { root.export-diagnostics(); }
                            }
                        }

                        TimelineHistogram { bins: root.log-timeline-bins; }

                        Rectangle {
                            height: 36px;
                            border-width: 1px;
                            border-color: Theme.border;
                            background: Theme.surface;

                            HorizontalLayout {
                                padding-left: 10px;
                                padding-right: 12px;
                                spacing: 12px;

                                Text { text: "Time"; width: 160px; color: Theme.text-muted; font-size: Theme.fs-label; vertical-alignment: center; }
                                Text { text: "Level"; width: 78px; color: Theme.text-muted; font-size: Theme.fs-label; vertical-alignment: center; }
                                Text { text: "Target"; width: 270px; color: Theme.text-muted; font-size: Theme.fs-label; vertical-alignment: center; overflow: elide; }
                                Text { text: "Message"; horizontal-stretch: 1; color: Theme.text-muted; font-size: Theme.fs-label; vertical-alignment: center; }
                            }
                        }

                        if root.log-entries.length == 0 : Rectangle {
                            vertical-stretch: 1;
                            border-radius: Theme.radius-sm;
                            border-width: 1px;
                            border-color: Theme.border;
                            background: Theme.surface;

                            Text {
                                text: root.log-status;
                                color: Theme.text-muted;
                                font-size: Theme.fs-label;
                                width: parent.width;
                                height: parent.height;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        if root.log-entries.length > 0 : ScrollView {
                            vertical-stretch: 1;

                            VerticalLayout {
                                spacing: 0px;

                                Rectangle {
                                    height: 32px;
                                    background: Theme.accent-soft;
                                    border-radius: 5px;

                                    HorizontalLayout {
                                        padding-left: 12px;
                                        spacing: 10px;

                                        Rectangle {
                                            width: 14px;
                                            height: parent.height;

                                            Image {
                                                source: Icons.live;
                                                width: 14px;
                                                height: 14px;
                                                x: (parent.width - self.width) / 2;
                                                y: (parent.height - self.height) / 2;
                                                colorize: Theme.accent;
                                            }
                                        }

                                        Text {
                                            text: root.log-live-enabled ? (root.log-active-target != "" ? "Live Mode - " + root.log-active-target : "Live Mode") : "Paused";
                                            color: Theme.accent;
                                            font-size: Theme.fs-label;
                                            vertical-alignment: center;
                                        }

                                        Rectangle { horizontal-stretch: 1; }

                                        Text {
                                            text: (root.log-is-truncated ? "showing last " + root.log-entries.length + " of " : "") + root.log-visible-count + " / " + root.log-total-count + " rows";
                                            color: Theme.text-muted;
                                            font-size: Theme.fs-small;
                                            vertical-alignment: center;
                                        }
                                    }
                                }

                                for row[index] in root.log-entries : VerticalLayout {
                                    vertical-stretch: 0;
                                    spacing: 0px;

                                    Rectangle {
                                        height: 37px;
                                        background: row-touch.has-hover ? Theme.table-row-hover : (Math.mod(index, 2) == 0 ? Theme.table-row : Theme.table-row-alt);

                                        row-touch := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => { root.toggle-log-row(row.id); }
                                        }

                                        HorizontalLayout {
                                            padding-left: 10px;
                                            padding-right: 12px;
                                            spacing: 12px;

                                            Rectangle {
                                                width: 18px;
                                                height: parent.height;
                                                Image {
                                                    source: row.expanded ? Icons.chevron-down : Icons.chevron-right;
                                                    width: 14px;
                                                    height: 14px;
                                                    x: (parent.width - self.width) / 2;
                                                    y: (parent.height - self.height) / 2;
                                                    colorize: Theme.text-muted;
                                                }
                                            }

                                            Text {
                                                text: row.time;
                                                width: 130px;
                                                color: Theme.text-muted;
                                                font-family: "Consolas";
                                                font-size: Theme.fs-mono;
                                                vertical-alignment: center;
                                                overflow: elide;
                                            }

                                            Rectangle {
                                                width: 78px;
                                                height: parent.height;
                                                LogPill {
                                                    text: row.level;
                                                    tone: row.level == "ERROR" ? Theme.danger : (row.level == "WARN" ? Theme.warning : (row.level == "INFO" ? Theme.success : Theme.accent));
                                                    y: (parent.height - self.height) / 2;
                                                }
                                            }

                                            Text {
                                                text: row.target;
                                                width: 270px;
                                                color: Theme.text-muted;
                                                font-family: "Consolas";
                                                font-size: Theme.fs-mono;
                                                vertical-alignment: center;
                                                overflow: elide;
                                            }

                                            Text {
                                                text: row.message;
                                                horizontal-stretch: 1;
                                                color: Theme.text;
                                                font-family: "Consolas";
                                                font-size: Theme.fs-mono;
                                                vertical-alignment: center;
                                                overflow: elide;
                                            }
                                        }
                                    }

                                    if row.expanded : Rectangle {
                                        height: Math.min(row.tree-nodes.length * 24px + 8px, 320px);
                                        background: Theme.surface;
                                        border-width: 1px;
                                        border-color: Theme.border;

                                        ScrollView {
                                            VerticalLayout {
                                                padding: 4px;
                                                for node in row.tree-nodes : ObjectTreeRow {
                                                    depth: node.depth;
                                                    key: node.key;
                                                    value-preview: node.value-preview;
                                                    value-type: node.value-type;
                                                    expandable: node.expandable;
                                                    expanded: node.expanded;
                                                    toggled => {
                                                        root.toggle-tree-node(row.id, node.node-id);
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }

                        HorizontalLayout {
                            height: 24px;
                            spacing: 12px;

                            Text {
                                text: root.log-status;
                                color: Theme.text-muted;
                                font-size: Theme.fs-small;
                                horizontal-stretch: 1;
                                vertical-alignment: center;
                                overflow: elide;
                            }

                            Text {
                                text: root.log-dir;
                                color: Theme.text-subtle;
                                font-size: Theme.fs-small;
                                vertical-alignment: center;
                                overflow: elide;
                            }
                        }
                    }
                }
            }
        }
    }

    // Draggable splitter handle (placed absolutely over the divider)
    Rectangle {
        x: Math.max(root.sidebar-width - 4px, 0px);
        width: 8px;
        height: 100%;
        background: transparent;

        splitter-touch := TouchArea {
            width: 100%;
            height: 100%;
            mouse-cursor: col-resize;
            moved => {
                if (splitter-touch.pressed) {
                    let new-width = root.sidebar-width + splitter-touch.mouse-x - splitter-touch.pressed-x;
                    if (new-width < 32px) {
                        root.sidebar-width = 0px;
                    } else if (new-width < 120px) {
                        root.sidebar-width = 64px;
                    } else {
                        root.sidebar-width = Math.min(Math.max(new-width, 64px), 320px);
                    }
                }
            }
        }
    }
}
}
