// Monochrome Lucide icons (https://lucide.dev, ISC license), tinted at runtime
// via `Image.colorize` so a single asset works in both light and dark themes.
export global Icons {
    // Section icons
    out property <image> general: @image-url("icons/sliders-horizontal.svg");
    out property <image> privacy: @image-url("icons/shield.svg");
    out property <image> network: @image-url("icons/globe.svg");
    out property <image> proxy: @image-url("icons/route.svg");
    out property <image> speed: @image-url("icons/gauge.svg");
    out property <image> updates: @image-url("icons/refresh-cw.svg");
    out property <image> logs: @image-url("icons/scroll-text.svg");

    // Action icons
    out property <image> refresh: @image-url("icons/rotate-cw.svg");
    out property <image> apply: @image-url("icons/check.svg");
    out property <image> folder: @image-url("icons/folder-open.svg");
    out property <image> export: @image-url("icons/download.svg");
    out property <image> search: @image-url("icons/search.svg");
    out property <image> filter: @image-url("icons/funnel.svg");
    out property <image> live: @image-url("icons/circle-stop.svg");
    out property <image> chevron-right: @image-url("icons/chevron-right.svg");
    out property <image> chevron-down: @image-url("icons/chevron-down.svg");
    out property <image> more: @image-url("icons/more-vertical.svg");

    // Header / branding
    out property <image> sun: @image-url("icons/sun.svg");
    out property <image> moon: @image-url("icons/moon.svg");
    out property <image> logo: @image-url("icons/logo.png");
}
